# -------------------------------------------------------------------
# Docker Compose (db / migrate サービス)
# -------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=jyogi_oauth
POSTGRES_PORT=5432

# -------------------------------------------------------------------
# API サーバー（cargo run -p api / ホスト直接起動用）
# 上記 POSTGRES_* の値を埋めた上で以下も同様に書き換える
# -------------------------------------------------------------------
DATABASE_URL=postgres://postgres:@localhost:5432/jyogi_oauth
LISTEN_ADDR=0.0.0.0:8080